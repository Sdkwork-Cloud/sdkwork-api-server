{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "motion/react": ["src/vendor/motion-react.tsx"],
      "@sdkwork/ui-pc-react": ["src/types/sdkwork-ui-pc-react-shim.d.ts"],
      "@sdkwork/ui-pc-react/theme": ["../../../sdkwork-ui/sdkwork-ui-pc-react/dist/theme/index.d.ts"],
      "@sdkwork/ui-pc-react/*": ["../../../sdkwork-ui/sdkwork-ui-pc-react/dist/*"],
      "@sdkwork/ui-pc-react/styles.css": [
        "../../../sdkwork-ui/sdkwork-ui-pc-react/dist/sdkwork-ui.css"
      ],
      "sdkwork-router-admin-apirouter": ["packages/sdkwork-router-admin-apirouter/src/index.ts"],
      "sdkwork-router-admin-admin-api": ["packages/sdkwork-router-admin-admin-api/src/index.ts"],
      "sdkwork-router-admin-auth": ["packages/sdkwork-router-admin-auth/src/index.tsx"],
      "sdkwork-router-admin-catalog": ["packages/sdkwork-router-admin-catalog/src/index.tsx"],
      "sdkwork-router-admin-commercial": ["packages/sdkwork-router-admin-commercial/src/index.tsx"],
      "sdkwork-router-admin-core": ["packages/sdkwork-router-admin-core/src/index.tsx"],
      "sdkwork-router-admin-coupons": ["packages/sdkwork-router-admin-coupons/src/index.tsx"],
      "sdkwork-router-admin-operations": ["packages/sdkwork-router-admin-operations/src/index.tsx"],
      "sdkwork-router-admin-overview": ["packages/sdkwork-router-admin-overview/src/index.tsx"],
      "sdkwork-router-admin-pricing": ["packages/sdkwork-router-admin-pricing/src/index.tsx"],
      "sdkwork-router-admin-settings": ["packages/sdkwork-router-admin-settings/src/index.tsx"],
      "sdkwork-router-admin-shell": ["packages/sdkwork-router-admin-shell/src/index.ts"],
      "sdkwork-router-admin-tenants": ["packages/sdkwork-router-admin-tenants/src/index.tsx"],
      "sdkwork-router-admin-traffic": ["packages/sdkwork-router-admin-traffic/src/index.tsx"],
      "sdkwork-router-admin-types": ["packages/sdkwork-router-admin-types/src/index.ts"],
      "sdkwork-router-admin-users": ["packages/sdkwork-router-admin-users/src/index.tsx"]
    }
  },
  "include": ["src", "packages/**/*.ts", "packages/**/*.tsx", "vite.config.ts"]
}
