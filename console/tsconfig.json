{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "sdkwork-api-admin-sdk": ["packages/sdkwork-api-admin-sdk/src/index.ts"],
      "sdkwork-api-channel": ["packages/sdkwork-api-channel/src/index.tsx"],
      "sdkwork-api-core": ["packages/sdkwork-api-core/src/index.ts"],
      "sdkwork-api-portal-auth": ["packages/sdkwork-api-portal-auth/src/index.tsx"],
      "sdkwork-api-portal-sdk": ["packages/sdkwork-api-portal-sdk/src/index.ts"],
      "sdkwork-api-portal-user": ["packages/sdkwork-api-portal-user/src/index.tsx"],
      "sdkwork-api-routing": ["packages/sdkwork-api-routing/src/index.tsx"],
      "sdkwork-api-runtime": ["packages/sdkwork-api-runtime/src/index.tsx"],
      "sdkwork-api-types": ["packages/sdkwork-api-types/src/index.ts"],
      "sdkwork-api-usage": ["packages/sdkwork-api-usage/src/index.tsx"],
      "sdkwork-api-workspace": ["packages/sdkwork-api-workspace/src/index.tsx"]
    }
  },
  "include": ["src", "packages/*/src"]
}
